# ── Grafana ──
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=


# ── Infisical ──
# AES-128 16 bytes: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=
INFISICAL_SITE_URL=

# Postgres connection string (matches INFISICAL_POSTGRES_* below)
INFISICAL_DB_CONNECTION_URI=postgresql://infisical:<password>@postgres:5432/infisical
INFISICAL_REDIS_URL=redis://redis:6379

# ── Infisical — PostgreSQL ──
INFISICAL_POSTGRES_DATABASE=infisical
INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=

# ── Infisical — SMTP (optional) ──
INFISICAL_SMTP_HOST=
INFISICAL_SMTP_PORT=465
INFISICAL_SMTP_SECURE=true
INFISICAL_SMTP_USERNAME=
INFISICAL_SMTP_PASSWORD=
INFISICAL_SMTP_FROM_NAME=Infisical
INFISICAL_SMTP_FROM_ADDRESS=


# ── Bifrost ──
BIFROST_POSTGRES_DATABASE=bifrost
BIFROST_POSTGRES_USER=bifrost
BIFROST_POSTGRES_PASSWORD=
BIFROST_ADMIN_USERNAME=
BIFROST_ADMIN_PASSWORD=
BIFROST_ENCRYPTION_KEY=


# ── Media stack (Jellyfin + *arr + qBittorrent) ──
# Absolute host path holding torrents/ and media/ on ONE filesystem (enables
# hardlinks on import). e.g. /srv/media
MEDIA_DATA=
# User/group that owns MEDIA_DATA and config/ (run `id` on the host).
MEDIA_PUID=1001
MEDIA_PGID=1001
MEDIA_TZ=Asia/Kolkata


# ── Terraform (optional) ──
# needs Zone:DNS:Edit and Zone:Zone:Read permissions for relevant domains
CLOUDFLARE_API_TOKEN=
